<Window x:Class="TextEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Текстовый редактор - Лабораторная работа 5"
        Height="820" Width="1200"
        MinHeight="650" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Создать" Click="CreateFile_Click" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Открыть" Click="OpenFile_Click" InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Сохранить" Click="SaveFile_Click" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Сохранить _как" Click="SaveAsFile_Click"/>
                <Separator/>
                <MenuItem Header="В_ыход" Click="Exit_Click" InputGestureText="Alt+F4"/>
            </MenuItem>

            <MenuItem Header="_Правка">
                <MenuItem Header="_Отменить" Click="Undo_Click" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Повторить" Click="Redo_Click" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="Вырезать" Click="Cut_Click" InputGestureText="Ctrl+X"/>
                <MenuItem Header="Копировать" Click="Copy_Click" InputGestureText="Ctrl+C"/>
                <MenuItem Header="Вставить" Click="Paste_Click" InputGestureText="Ctrl+V"/>
                <MenuItem Header="Удалить" Click="Delete_Click"/>
                <Separator/>
                <MenuItem Header="Выделить _все" Click="SelectAll_Click" InputGestureText="Ctrl+A"/>
            </MenuItem>

            <MenuItem Header="_Текст">
                <MenuItem Header="Постановка задачи" Click="TaskDescription_Click"/>
                <MenuItem Header="Грамматика" Click="Grammar_Click"/>
                <MenuItem Header="Классификация грамматики" Click="GrammarClassification_Click"/>
                <MenuItem Header="Метод анализа" Click="AnalysisMethod_Click"/>
                <MenuItem Header="Тестовый пример" Click="TestExample_Click"/>
                <MenuItem Header="Список литературы" Click="References_Click"/>
                <MenuItem Header="Исходный код программы" Click="SourceCode_Click"/>
            </MenuItem>

            <MenuItem Header="П_уск" Click="StartAnalysis_Click" InputGestureText="F5"/>

            <MenuItem Header="_Справка">
                <MenuItem Header="Вызов _справки" Click="Help_Click" InputGestureText="F1"/>
                <MenuItem Header="_О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <ToolBar DockPanel.Dock="Top" Height="40">
            <Button Click="CreateFile_Click" ToolTip="Создать документ (Ctrl+N)" Style="{StaticResource IconButtonStyle}">
                <TextBlock Text="N" FontWeight="Bold"/>
            </Button>
            <Button Click="OpenFile_Click" ToolTip="Открыть документ (Ctrl+O)" Style="{StaticResource IconButtonStyle}">
                <TextBlock Text="O" FontWeight="Bold"/>
            </Button>
            <Button Click="SaveFile_Click" ToolTip="Сохранить (Ctrl+S)" Style="{StaticResource IconButtonStyle}">
                <TextBlock Text="S" FontWeight="Bold"/>
            </Button>
            <Separator/>
            <Button Click="Undo_Click" ToolTip="Отменить (Ctrl+Z)" Style="{StaticResource IconButtonStyle}">
                <TextBlock Text="↶" FontSize="16"/>
            </Button>
            <Button Click="Redo_Click" ToolTip="Повторить (Ctrl+Y)" Style="{StaticResource IconButtonStyle}">
                <TextBlock Text="↷" FontSize="16"/>
            </Button>
            <Separator/>
            <Button Click="Cut_Click" ToolTip="Вырезать (Ctrl+X)" Style="{StaticResource IconButtonStyle}">
                <TextBlock Text="✂" FontSize="14"/>
            </Button>
            <Button Click="Copy_Click" ToolTip="Копировать (Ctrl+C)" Style="{StaticResource IconButtonStyle}">
                <TextBlock Text="C" FontWeight="Bold"/>
            </Button>
            <Button Click="Paste_Click" ToolTip="Вставить (Ctrl+V)" Style="{StaticResource IconButtonStyle}">
                <TextBlock Text="P" FontWeight="Bold"/>
            </Button>
            <Separator/>
            <Button Click="StartAnalysis_Click" ToolTip="Запуск анализа (F5)" Style="{StaticResource IconButtonStyle}">
                <TextBlock Text="▶" FontSize="16" Foreground="Green"/>
            </Button>
            <Separator/>
            <Button Click="Help_Click" ToolTip="Справка (F1)" Style="{StaticResource IconButtonStyle}">
                <TextBlock Text="?" FontWeight="Bold" Foreground="Blue"/>
            </Button>
            <Button Click="About_Click" ToolTip="О программе" Style="{StaticResource IconButtonStyle}">
                <TextBlock Text="i" FontWeight="Bold" Foreground="Blue"/>
            </Button>
        </ToolBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>

            <RichTextBox x:Name="EditorBox"
                         Grid.Row="0"
                         Margin="5"
                         FontFamily="Consolas"
                         FontSize="14"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         AcceptsTab="True"
                         SpellCheck.IsEnabled="False"
                         SelectionChanged="EditorBox_SelectionChanged"
                         TextChanged="EditorBox_TextChanged">
                <RichTextBox.Resources>
                    <Style TargetType="{x:Type Paragraph}">
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>

            <GridSplitter Grid.Row="1"
                          Height="5"
                          HorizontalAlignment="Stretch"
                          Background="LightGray"
                          ShowsPreview="True"/>

            <TabControl Grid.Row="2" Margin="5">
                <TabItem Header="Лексический анализ">
                    <DataGrid x:Name="ResultsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionChanged="ResultsGrid_SelectionChanged"
                              Background="White"
                              BorderBrush="Gray"
                              BorderThickness="1"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="70"/>
                            <DataGridTextColumn Header="Тип лексемы" Binding="{Binding Type}" Width="180"/>
                            <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="*" MinWidth="120"/>
                            <DataGridTextColumn Header="Строка" Binding="{Binding Line}" Width="70"/>
                            <DataGridTextColumn Header="Позиция (с-по)" Width="110">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding StringFormat="{}{0} - {1}">
                                        <Binding Path="StartPosition"/>
                                        <Binding Path="EndPosition"/>
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Ошибка" Binding="{Binding ErrorMessage}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Синтаксические ошибки">
                    <DockPanel>
                        <TextBlock x:Name="SyntaxErrorCountText"
                                   DockPanel.Dock="Top"
                                   Margin="5"
                                   FontWeight="Bold"
                                   Foreground="DarkRed"
                                   Text="Синтаксических ошибок: 0"/>
                        <DataGrid x:Name="SyntaxErrorsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionChanged="SyntaxErrorsGrid_SelectionChanged"
                                  Background="White"
                                  BorderBrush="Gray"
                                  BorderThickness="1"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Неверный фрагмент" Binding="{Binding InvalidFragment}" Width="*" MinWidth="120"/>
                                <DataGridTextColumn Header="Местоположение" Binding="{Binding Location}" Width="150"/>
                                <DataGridTextColumn Header="Описание ошибки" Binding="{Binding Description}" Width="2*" MinWidth="250"/>
                                <DataGridTextColumn Header="Ожидалось" Binding="{Binding Expected}" Width="170"/>
                                <DataGridTextColumn Header="Найдено" Binding="{Binding Found}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <TabItem Header="AST">
                    <TextBox x:Name="AstOutputTextBox"
                             Margin="5"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="14"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>
                </TabItem>

                <TabItem Header="Семантические ошибки">
                    <DockPanel>
                        <TextBlock x:Name="SemanticErrorCountText"
                                   DockPanel.Dock="Top"
                                   Margin="5"
                                   FontWeight="Bold"
                                   Foreground="DarkRed"
                                   Text="Семантических ошибок: 0"/>
                        <DataGrid x:Name="SemanticErrorsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionChanged="SemanticErrorsGrid_SelectionChanged"
                                  Background="White"
                                  BorderBrush="Gray"
                                  BorderThickness="1"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Сообщение" Binding="{Binding Message}" Width="2*" MinWidth="350"/>
                                <DataGridTextColumn Header="Местоположение" Binding="{Binding Location}" Width="170"/>
                                <DataGridTextColumn Header="Фрагмент" Binding="{Binding Fragment}" Width="*" MinWidth="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Grid>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готов к работе"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="CursorPositionText" Text="Стр: 1, Стб: 1"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="FileInfoText" Text="Новый документ"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="ErrorCountText" Text="Общее количество ошибок: 0" FontWeight="Bold"/>
            </StatusBarItem>
        </StatusBar>
    </DockPanel>
</Window>
